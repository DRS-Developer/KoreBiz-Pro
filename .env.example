
# Supabase Configuration
# -------------------------------------------------------------------------
# OPTION A: Manual Configuration (Recommended for Vite/Local Dev)
# Use these variables if you are copying keys manually from Supabase Dashboard.
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# OPTION B: Vercel Native Integration (Automated)
# These are automatically injected by Vercel if you use the Marketplace Integration.
# You can also use them locally if you prefer Next.js conventions.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# -------------------------------------------------------------------------

# EmailJS Configuration (Optional - For Contact Form)
# Get these from https://dashboard.emailjs.com/
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
